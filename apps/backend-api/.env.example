# BioLogik API — Environment Variables
# Copy this file to .env and adjust values for your local setup.

# ── General ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biologik

# ── JWT Auth ─────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ── Security ─────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12
